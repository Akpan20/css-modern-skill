{
  "name": "css-modern-skill",
  "version": "1.0.0",
  "description": "CSS Modern Reference & Layout Architect Skill",
  "private": true,
  "scripts": {
    "lint:css": "stylelint \"**/*.css\" --formatter verbose",
    "lint:md": "markdownlint-cli2 \"**/*.md\" --config .markdownlint-cli2.jsonc --ignore-path .markdownlintignore",
    "check:browsers": "browserslist",
    "validate": "npm run lint:css && npm run lint:md && npm run check:browsers"
  },
  "devDependencies": {
    "stylelint": "^16.0.0",
    "stylelint-config-recommended": "^14.0.0",
    "stylelint-config-standard": "^36.0.0",
    "markdownlint-cli2": "^0.13.0",
    "browserslist": "^4.23.0",
    "caniuse-lite": "^1.0.30001600"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "Chrome >= 115",
    "Firefox >= 115",
    "Safari >= 16.4"
  ]
}
